#!/bin/bash
# pre-push hook: 阻止直接推送到 main 分支
# 团队成员必须通过 Pull Request 合并代码

protected_branch="main"

while read local_ref local_sha remote_ref remote_sha; do
    if [ "$remote_ref" = "refs/heads/$protected_branch" ]; then
        echo ""
        echo "================================================"
        echo "  ⛔ 禁止直接推送到 $protected_branch 分支！"
        echo "================================================"
        echo ""
        echo "  请按以下步骤操作："
        echo ""
        echo "  1. 切换到你的功能分支："
        echo "     git checkout feature/你的模块名"
        echo ""
        echo "  2. 推送功能分支："
        echo "     git push origin feature/你的模块名"
        echo ""
        echo "  3. 在 GitHub 上创建 Pull Request："
        echo "     https://github.com/xiabai2004/quantum-rl-scheduler/pulls"
        echo ""
        echo "  4. 等待至少 1 人 Review 通过后合并"
        echo ""
        echo "  ⚠️ 紧急绕过（仅限个人开发/管理员）："
        echo "     git push --no-verify origin main"
        echo ""
        echo "  如有问题请联系项目经理。"
        echo "================================================"
        echo ""
        exit 1
    fi
done

exit 0
