#!/bin/bash
# commit-msg hook: 检查 commit message 规范
# 确保所有提交遵循 <type>: <描述> 格式
# 注意: commit-msg hook 接收 commit message 文件路径作为 $1

commit_regex='^(feat|fix|refactor|test|docs|style|perf|chore|merge|ci|build)(\(.+\))?: .+'
error_msg="
================================================
  Commit Message 格式不符合规范！

  正确格式: <type>: <简短描述>

  可选 type:
    feat      新功能
    fix       修复Bug
    refactor  重构（不改功能）
    test      添加测试
    docs      文档更新
    style     代码格式
    perf      性能优化
    chore     构建/工具变更
    merge     合并分支
    ci        CI配置
    build     构建系统

  示例:
    feat: 实现DQN智能体训练循环
    fix: 修复量子退火QUBO矩阵维度不匹配
    docs: 更新API接口文档
================================================
"

if ! grep -qE "$commit_regex" "$1"; then
    echo "$error_msg"
    exit 1
fi

exit 0
