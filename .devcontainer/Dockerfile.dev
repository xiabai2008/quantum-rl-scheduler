# =============================================================================
# 开发容器 Dockerfile
# 基于 Python 3.11，包含所有开发和调试工具
# 支持通过构建参数启用 GPU（CUDA/cuDNN）
#
# CPU 模式（默认）：docker build -f .devcontainer/Dockerfile.dev .
# GPU 模式：docker build --build-arg BASE_IMAGE=nvidia/cuda:11.8.0-cudnn8-runtime-ubuntu22.04 -f .devcontainer/Dockerfile.dev .
# =============================================================================

# 基础镜像（通过构建参数切换 CPU/GPU）
ARG BASE_IMAGE=python:3.11-slim
FROM ${BASE_IMAGE}

# 如果使用 CUDA 基础镜像，需要安装 Python
ARG BASE_IMAGE=python:3.11-slim
RUN if echo "${BASE_IMAGE}" | grep -q "cuda"; then \
        apt-get update && apt-get install -y --no-install-recommends \
        python3.11 python3.11-dev python3-pip \
        && ln -sf /usr/bin/python3.11 /usr/bin/python \
        && ln -sf /usr/bin/pip3 /usr/bin/pip \
        && rm -rf /var/lib/apt/lists/*; \
    fi

# 系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    git \
    git-lfs \
    wget \
    vim \
    htop \
    bash-completion \
    libgomp1 \
    libgl1-mesa-glx \
    libglib2.0-0 \
    graphviz \
    && rm -rf /var/lib/apt/lists/*

# GPU 健康检查（仅在 CUDA 环境下可用）
RUN if command -v nvidia-smi &> /dev/null; then \
        echo "GPU support detected"; \
    else \
        echo "CPU-only mode (no nvidia-smi)"; \
    fi

# 创建非 root 用户
RUN useradd -m -s /bin/bash vscode \
    && echo "vscode ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# 设置工作目录
WORKDIR /workspace

# 先复制 requirements.txt 利用 Docker 缓存
COPY requirements.txt .

# 安装 Python 依赖
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt \
    && pip install --no-cache-dir \
        ipykernel \
        debugpy \
        pytest-watch \
        pre-commit \
        bandit \
        safety

# 切换到非 root 用户
USER vscode

# 设置环境变量
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/workspace \
    PIP_NO_CACHE_DIR=1
