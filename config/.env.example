# 天衍云平台 API 配置
# 复制此文件为 .env 并填写真实值
# 警告：请勿将真实凭证提交到版本控制系统！

# ──────────────────────────────────────────────────────────────
# 天衍云 API 凭证（真实模式必需，Mock 模式可留空）
# ──────────────────────────────────────────────────────────────
# API 主密钥：从天衍云个人中心获取，真实模式必需
# 别名：TIANYAN_API_TOKEN（与 TIANYAN_API_KEY 等效，二选一即可）
TIANYAN_API_KEY=your_api_key_here
# API 密钥别名（与 TIANYAN_API_KEY 等效，设置其一即可）
TIANYAN_API_TOKEN=your_api_token_here
# API Secret（可选，仅当平台要求双因子认证时填写）
TIANYAN_API_SECRET=your_api_secret_here
# 应用 ID（可选，仅当使用应用级鉴权时填写）
TIANYAN_APP_ID=your_app_id_here

# ──────────────────────────────────────────────────────────────
# 量子计算机后端配置
# ──────────────────────────────────────────────────────────────
# 默认量子计算机名称（真实模式使用，可选值见 tianyan_cqlib.REAL_MACHINES）
TIANYAN_MACHINE=tianyan_s

# ──────────────────────────────────────────────────────────────
# Mock 模式配置（开发阶段推荐使用）
# ──────────────────────────────────────────────────────────────
# Mock 模式开关（true: 使用 Mock API，无需真实平台，可离线开发）
TIANYAN_MOCK_MODE=true
# Mock 模式模拟延迟（秒），模拟真实网络延迟
TIANYAN_MOCK_DELAY=1.0
# Mock 模式模拟失败率（0-1），用于测试异常处理
TIANYAN_MOCK_FAILURE_RATE=0.0

# ──────────────────────────────────────────────────────────────
# API 请求超时与重试（可选，未设置时使用默认值）
# ──────────────────────────────────────────────────────────────
# 单次 API 请求超时时间（秒），默认 30.0
TIANYAN_API_TIMEOUT=30.0
# API 请求失败最大重试次数，默认 3
TIANYAN_API_MAX_RETRIES=3
# 重试间隔（秒），默认 1.0
TIANYAN_API_RETRY_DELAY=1.0

# ──────────────────────────────────────────────────────────────
# 通用配置
# ──────────────────────────────────────────────────────────────
# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO
# 数据库路径（SQLite）
DATABASE_PATH=data/scheduler.db
# Redis 配置（如果使用 Redis 缓存）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ──────────────────────────────────────────────────────────────
# Web 界面配置（可选）
# ──────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_DEBUG=true

# ──────────────────────────────────────────────────────────────
# 量子退火配置（可选）
# ──────────────────────────────────────────────────────────────
# 退火模块开关（true: 启用退火优化，false: 纯 RL 训练）
ANNEALING_ENABLED=true
# 退火模拟模式（true: 使用经典模拟退火，false: 尝试连接真实量子退火机）
ANNEALING_SIMULATION=true
