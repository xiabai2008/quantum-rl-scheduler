# =============================================================================
# Docker 构建忽略文件 — Issue #116
# 目标：镜像体积减少 50-80%，构建时间大幅缩短
# =============================================================================

# --- Git ---
.git
.gitignore
.gitattributes

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg
dist/
build/
*.whl

# --- 虚拟环境 ---
venv/
env/
.venv/
ENV/

# --- IDE / 编辑器 ---
.idea/
.vscode/
.trae/
.editorconfig
*.swp
*.swo
*~
.DS_Store

# --- CI / DevContainer / GitHub（容器内不需要） ---
.github/
.devcontainer/

# --- 测试 ---
.coverage
htmlcov/
.pytest_cache/
tests/

# --- 文档（容器内不需要 .md / .rst） ---
docs/
*.md
*.rst
!requirements.txt

# --- 日志（可能数百 MB） ---
logs/
*.log

# --- 大型运行时产物（应通过 Docker volume 挂载） ---
models/
results/
tensorboard_logs/

# --- 检查点 & 模型权重 ---
*.ckpt
*.h5
*.pth
*.pt

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- 环境变量（绝对不能进镜像） ---
.env
.env.*
!.env.example

# --- Node.js / 前端 ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- 临时文件 ---
*.tmp
temp/
tmp/

# --- 媒体文件 & 二进制文档（PPT/PDF/图片/视频） ---
*.jpg
*.jpeg
*.png
*.gif
*.svg
*.pdf
*.pptx
*.docx
*.xlsx
*.mp4
*.mov
*.avi

# --- LICENSE 保留（Docker 不需要） ---
# LICENSE 已通过 *.md / *.rst 排除，无需额外规则
