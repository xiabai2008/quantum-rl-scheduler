# 天衍云平台 API 配置
# 复制此文件为 .env 并填写真实值

# 天衍云 API 密钥（真实模式需要，Mock 模式可随意填写）
TIANYAN_API_KEY=your_api_key_here
TIANYAN_API_SECRET=your_api_secret_here

# Mock 模式配置（开发阶段推荐使用）
# true: 使用 Mock API（无需真实平台，可离线开发）
# false: 使用真实 API（需要有效 API Key 和平台访问权限）
TIANYAN_MOCK_MODE=true

# Mock 模式模拟延迟（秒），模拟真实网络延迟
TIANYAN_MOCK_DELAY=1.0

# Mock 模式模拟失败率（0-1），用于测试异常处理
TIANYAN_MOCK_FAILURE_RATE=0.0

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO

# 数据库路径（SQLite）
DATABASE_PATH=data/scheduler.db

# Redis 配置（如果使用 Redis 缓存）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
